{
  "icon": "data:image/svg+xml;base64,",
  "lang": "javascript",
  "script": "function process(data) {\n    // extract SQL statement\n    const preparing = data.selection.match(/Preparing:\\s*(.+?)(?=\\n|$)/);\n    if (!preparing) {\n        throw new Error('Cannot find SQL statement');\n    }\n    const sql = preparing[1].trim();\n\n    // extract parameters\n    const parameters = data.selection.match(/Parameters:\\s*(.+?)(?=\\n|$)/);\n    if (!parameters) {\n        // return SQL directly\n        return sql;\n    }\n\n    // parse parameters\n    const params = parse(parameters[1].trim());\n\n    // replace placeholders in SQL\n    let index = 0;\n    const result = sql.replace(/\\?/g, () => {\n        if (index >= params.length) {\n            throw new Error('Parameter count mismatch');\n        }\n        return params[index++];\n    });\n\n    return result;\n}\n\nfunction parse(parameters) {\n    // split parameters by comma, and extract value and type using regex\n    const regex = /([^,()]+)(?:\\(([^)]+)\\))?(?:,\\s*|$)/g;\n    return [...parameters.matchAll(regex)].map((m) =>\n        format(m[1].trim(), m[2]?.trim()),\n    );\n}\n\nfunction format(value, type) {\n    // handle null value\n    if (!type && value === 'null') {\n        return 'NULL';\n    }\n\n    // handle boolean type\n    if (type === 'Boolean') {\n        return value.toLowerCase() === 'true' ? '1' : '0';\n    }\n\n    // handle string types\n    if (\n        type === 'String' ||\n        type === 'Date' ||\n        type === 'Time' ||\n        type === 'LocalDate' ||\n        type === 'LocalTime' ||\n        type === 'LocalDateTime' ||\n        type === 'Timestamp'\n    ) {\n        return `'${value.replace(/'/g, \"''\")}'`;\n    }\n\n    return value;\n}\n",
  "locales": {
    "en": {
      "name": "MyBatis Log",
      "description": "Parse MyBatis log to extract SQL statements with parameters.",
